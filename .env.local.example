# Copy this file to .env.local and fill in your key.
# Get one at https://console.anthropic.com/ -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: cross-device sync ---
# Only needed if you want two phones to share one live household. Add a KV /
# Upstash Redis store to your Vercel project (Storage tab) and these get set
# automatically. Without them, the app runs fully local (sync just stays off).
# KV_REST_API_URL=https://xxxxx.upstash.io
# KV_REST_API_TOKEN=xxxxxxxx
