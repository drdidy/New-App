//@version=6
indicator("Prophet Map Pro", shorttitle="PM Pro", overlay=true, max_lines_count=80, max_labels_count=24, calc_bars_count=9000)

// ============================================================================
// Prophet Map Pro -- market structure map. No trade engine, no backtest stats.
//
// Three layers, strongest to faintest:
//   1) WEEKLY CONTROL (bold red/green bands)
//        Monday 12:00-2:30pm CT high wick, projected down 1.04 pts per
//        trading hour through the week. Gates every 34 pts. Primary layer.
//   2) DAILY CONTROL (thin dashed red/green)
//        Same-day 4:00-5:00am CT high wick, same slope and spacing.
//        Active 8:50am-3:00pm CT. Tactical context, not the main map.
//   3) MACRO LATTICE (purple zones)
//        Fixed daily grid from two hard anchors, +/-6.5 pts per RTH trading
//        day, gates every 170 pts. All four in-play rails are drawn and
//        labeled as zones (dark purple center line, faint edges, soft fill):
//        support and resistance from the descending grid AND from the
//        ascending grid. Sits under Weekly and Daily in visual weight.
//
// Stability rules honored throughout:
//   - Anchor highs AND their projected current values are computed on fixed
//     30-min (weekly) and 5-min (daily) feeds via request.security with
//     lookahead off, so the levels are identical on 1m, 5m, 15m, 30m and
//     1h charts. No chart-interval bar counting is involved.
//   - The Macro Lattice counts ACTUAL daily trading bars of the symbol
//     (request.security "D"), not calendar weekdays, so market holidays do
//     not shift the grid.
//   - Lines use xloc.bar_time with extend.right: no future bar_index, no
//     visible-range math, nothing recalculates or shifts when zooming.
//   - Anchors publish only after their window completes: no repainting.
// ============================================================================

string TZ = "America/Chicago"

// ---------------------------------------------------------------------------
// Inputs (all display.none -- no status-line spam)
// ---------------------------------------------------------------------------
gP = "Instrument profile"
profile = input.string("Auto", "Profile", options=["Auto", "SPX/ES", "SPY"], group=gP, display=display.none)

gW = "Weekly Control"
showWeekly = input.bool(true, "Show Weekly Control", group=gW, display=display.none)
weeklySession = input.session("1200-1430:2", "Monday anchor window (CT)", group=gW, tooltip="Monday 12:00pm-2:30pm CT. The completed high wick of this window becomes the weekly descending control for the whole week.", display=display.none)
showWeeklyGuides = input.bool(true, "Faint next weekly shelves", group=gW, tooltip="One unlabeled dotted shelf beyond the current weekly range on each side.", display=display.none)

gD = "Daily Control"
showDailyIn = input.bool(true, "Show Daily Control", group=gD, display=display.none)
dailySession = input.session("0400-0500:23456", "AM anchor window (CT)", group=gD, tooltip="Same-day 4:00-5:00am CT high wick. Needs premarket bars (ES futures). SPX index charts have none, so the daily layer stays empty there.", display=display.none)
dailyActive = input.session("0850-1500:23456", "Daily layer active window (CT)", group=gD, tooltip="The daily layer draws only inside this window. Default 8:50am-3:00pm CT.", display=display.none)

gM = "Macro Lattice"
showMacroIn = input.bool(true, "Show Macro Lattice", group=gM, display=display.none)
descPrice = input.float(7616.5, "Descending anchor price", group=gM, display=display.none)
descDate = input.time(timestamp("03 Jun 2026 12:00:00 GMT-5"), "Descending anchor date", group=gM, display=display.none)
ascPrice = input.float(7222.6, "Ascending anchor price", group=gM, display=display.none)
ascDate = input.time(timestamp("11 Jun 2026 12:00:00 GMT-5"), "Ascending anchor date", group=gM, display=display.none)
macroSlope = input.float(6.5, "Macro slope (pts per RTH day)", minval=0.0, group=gM, display=display.none)
macroSpace = input.float(170.0, "Macro gate spacing", minval=1.0, group=gM, display=display.none)
macroZone = input.float(8.0, "Macro zone width", minval=0.0, group=gM, tooltip="Reaction band width around each macro rail, drawn like the weekly zones: a dark center line with faint edges and a soft fill.", display=display.none)

gV = "Display"
theme = input.string("Light", "Theme", options=["Light", "Midnight"], group=gV, display=display.none)
showPanel = input.bool(true, "Show map panel", group=gV, display=display.none)
panelPosIn = input.string("Bottom right", "Panel position", options=["Top right", "Top left", "Bottom right", "Bottom left", "Middle right"], group=gV, display=display.none)
showGlow = input.bool(true, "Highlight shelf approaches", group=gV, tooltip="Soft red/green chart tint while price is testing the nearest shelf.", display=display.none)
enableAlerts = input.bool(false, "Use alert() messages", group=gV, display=display.none)
approachIn = input.float(0.0, "Approach distance (0 = auto)", minval=0.0, step=0.1, group=gV, display=display.none)

// ---------------------------------------------------------------------------
// Profile, model constants, colors
// ---------------------------------------------------------------------------
tickerUpper = str.upper(syminfo.ticker)
autoSpy = str.contains(tickerUpper, "SPY") and not str.contains(tickerUpper, "SPX")
isSpyProfile = profile == "SPY" or (profile == "Auto" and autoSpy)
slopeHour = isSpyProfile ? 0.12 : 1.04     // pts per trading hour
shelfSpacing = isSpyProfile ? 3.4 : 34.0   // intraday gate spacing
zoneWidth = isSpyProfile ? 0.4 : 4.0       // weekly reaction band width
approach = approachIn > 0 ? approachIn : shelfSpacing * 0.18
perBar = slopeHour * timeframe.in_seconds() / 3600.0
tfMs = timeframe.in_seconds() * 1000
intradayOk = timeframe.isintraday

colText = theme == "Light" ? #111827 : #F8FAFC
colMuted = theme == "Light" ? #64748B : #94A3B8
colPanel = theme == "Light" ? color.new(#FFFFFF, 4) : color.new(#111827, 5)
colHdr = theme == "Light" ? #E5E7EB : #1E293B
colRes = #C64949    // controlled red: resistance
colSup = #2E9C67    // controlled green: support
colMacro = #8A80B0  // muted purple: macro lattice
colGuide = theme == "Light" ? color.new(#111827, 78) : color.new(#F8FAFC, 78)

// ---------------------------------------------------------------------------
// Storage and helpers
// ---------------------------------------------------------------------------
var array<line> lines = array.new<line>()
var array<label> labels = array.new<label>()
var array<linefill> fills = array.new<linefill>()

clearObjects() =>
    while array.size(lines) > 0
        line.delete(array.pop(lines))
    while array.size(labels) > 0
        label.delete(array.pop(labels))
    while array.size(fills) > 0
        linefill.delete(array.pop(fills))

fmt(float v) =>
    na(v) ? "-" : str.tostring(v, format.mintick)

dateKeyOf(int t) =>
    year(t, TZ) * 10000 + month(t, TZ) * 100 + dayofmonth(t, TZ)

// Nearest gate below and above current price on a lattice centered at ctrl.
gatesAround(float ctrl, float spacing) =>
    float lo = na
    float hi = na
    if not na(ctrl) and spacing > 0
        float k = math.floor((close - ctrl) / spacing)
        lo := ctrl + k * spacing
        hi := lo + spacing
    [lo, hi]

send(string msg) =>
    if enableAlerts and barstate.isrealtime
        alert(msg, alert.freq_once_per_bar_close)

// ---------------------------------------------------------------------------
// Anchor engines -- fixed lower-timeframe feeds, interval-proof, no repaint.
// Each engine publishes its high wick only after the window completes, and
// also projects the CURRENT control value on its own feed, so both the
// anchor and the live value are identical on every chart interval.
// ---------------------------------------------------------------------------
// Weekly: high wick of Monday 12:00-2:30pm CT, decaying on the 30-min feed.
weeklyEngine() =>
    bool inW = not na(time(timeframe.period, weeklySession, TZ))
    bool newW = inW and not (inW[1] == true)
    bool endW = not inW and (inW[1] == true)
    var float winHigh = na
    var int winHighT = na
    var int winHighB = na
    var float wH = na
    var int wT = na
    var int wB = na
    if newW
        winHigh := high
        winHighT := time
        winHighB := bar_index
    else if inW and (na(winHigh) or high > winHigh)
        winHigh := high
        winHighT := time
        winHighB := bar_index
    if endW and not na(winHigh)
        wH := winHigh
        wT := winHighT
        wB := winHighB
        winHigh := na
        winHighT := na
        winHighB := na
    float wNowF = na(wH) or na(wB) ? na : wH - slopeHour * timeframe.in_seconds() / 3600.0 * (bar_index - wB)
    [wH, wT, wNowF]

// Daily: high wick of the same-day 4:00-5:00am CT window, published at 5:00,
// decaying on the 5-min feed.
dailyEngine() =>
    int dk = dateKeyOf(time)
    bool inW = not na(time(timeframe.period, dailySession, TZ))
    bool newW = inW and not (inW[1] == true)
    bool endW = not inW and (inW[1] == true)
    var float winHigh = na
    var int winHighT = na
    var int winHighB = na
    var float dH = na
    var int dT = na
    var int dB = na
    var int dDay = na
    if newW
        winHigh := high
        winHighT := time
        winHighB := bar_index
    else if inW and (na(winHigh) or high > winHigh)
        winHigh := high
        winHighT := time
        winHighB := bar_index
    if endW and not na(winHigh)
        dH := winHigh
        dT := winHighT
        dB := winHighB
        dDay := dk
        winHigh := na
        winHighT := na
        winHighB := na
    float dNowF = na(dH) or na(dB) ? na : dH - slopeHour * timeframe.in_seconds() / 3600.0 * (bar_index - dB)
    [dH, dT, dDay, dNowF]

[aWH, aWT, aWNow] = request.security(syminfo.tickerid, "30", weeklyEngine(), lookahead=barmerge.lookahead_off)
[aDH, aDT, aDDay, aDNow] = request.security(syminfo.tickerid, "5", dailyEngine(), lookahead=barmerge.lookahead_off)

// ---------------------------------------------------------------------------
// Macro Lattice -- counts the symbol's ACTUAL daily trading bars since each
// anchor date (holidays therefore do not shift the grid). Deterministic:
// same symbol + same date always yields the same trading-day count.
// ---------------------------------------------------------------------------
int descKey = dateKeyOf(descDate)
int ascKey = dateKeyOf(ascDate)

macroDayEngine() =>
    // time_close dates a daily bar by its trade date (futures daily bars
    // open the prior evening, so the open time would be off by one day).
    int dkc = dateKeyOf(time_close)
    var int descIdx = na
    var int ascIdx = na
    if na(descIdx) and dkc >= descKey
        descIdx := bar_index
    if na(ascIdx) and dkc >= ascKey
        ascIdx := bar_index
    [bar_index, descIdx, ascIdx]

[dayIdxNow, dayIdxDesc, dayIdxAsc] = request.security(syminfo.tickerid, "D", macroDayEngine(), lookahead=barmerge.lookahead_off)

int tdDesc = na(dayIdxDesc) ? na : dayIdxNow - dayIdxDesc
int tdAsc = na(dayIdxAsc) ? na : dayIdxNow - dayIdxAsc
float mDesc = na(tdDesc) ? na : descPrice - macroSlope * tdDesc
float mAsc = na(tdAsc) ? na : ascPrice + macroSlope * tdAsc
[mdLo, mdHi] = gatesAround(mDesc, macroSpace)
[maLo, maHi] = gatesAround(mAsc, macroSpace)
float mSup = na(mdLo) ? maLo : na(maLo) ? mdLo : math.max(mdLo, maLo)
float mRes = na(mdHi) ? maHi : na(maHi) ? mdHi : math.min(mdHi, maHi)

// Rendering anchor for the macro rails. Time coordinates that fall far
// before the first loaded chart bar are mis-positioned by TradingView (a
// 1-min chart loads only days of history, while the macro anchors are
// weeks back), so lines must start inside the loaded range. Capture the
// first loaded bar's time and its trading-day counts; the rail's value
// there is computed exactly from the daily-bar count, so the drawn segment
// is correct at both ends on every timeframe down to 1 minute.
var int tMacroFirst = na
var int tdDescFirst = na
var int tdAscFirst = na
if na(tMacroFirst) and not na(tdDesc) and not na(tdAsc)
    tMacroFirst := time
    tdDescFirst := tdDesc
    tdAscFirst := tdAsc

// ---------------------------------------------------------------------------
// Layer values and liveness
// ---------------------------------------------------------------------------
float wNow = aWNow
[wSup, wRes] = gatesAround(wNow, shelfSpacing)
bool weeklyLive = showWeekly and intradayOk and not na(wNow)

int dateKey = dateKeyOf(time)
bool dailyToday = not na(aDDay) and aDDay == dateKey
float dNow = dailyToday ? aDNow : na
[dSup, dRes] = gatesAround(dNow, shelfSpacing)
bool dailyWindowOn = not na(time(timeframe.period, dailyActive, TZ))
bool dailyLive = showDailyIn and intradayOk and dailyWindowOn and not na(dNow)

bool macroLive = showMacroIn and not isSpyProfile and not na(mSup) and not na(mRes)

// Nearest actionable gates across all live layers.
float nRes = na
float nSup = na
string resLayer = "-"
string supLayer = "-"
if weeklyLive
    nRes := wRes
    resLayer := "Weekly"
    nSup := wSup
    supLayer := "Weekly"
if dailyLive
    if not na(dRes) and (na(nRes) or dRes < nRes)
        nRes := dRes
        resLayer := "Daily"
    if not na(dSup) and (na(nSup) or dSup > nSup)
        nSup := dSup
        supLayer := "Daily"
if macroLive
    if not na(mRes) and (na(nRes) or mRes < nRes)
        nRes := mRes
        resLayer := "Macro"
    if not na(mSup) and (na(nSup) or mSup > nSup)
        nSup := mSup
        supLayer := "Macro"

float distRes = na(nRes) ? na : nRes - close
float distSup = na(nSup) ? na : close - nSup
bool hasMap = not na(nRes) and not na(nSup)
bool nearRes = not na(distRes) and distRes >= 0 and distRes <= approach
bool nearSup = not na(distSup) and distSup >= 0 and distSup <= approach
bool rthOpen = not na(time(timeframe.period, "0830-1500:23456", TZ))

string mapState = not intradayOk ? "USE INTRADAY" : not hasMap ? "NO MAP YET" : nearRes ? "AT RESISTANCE" : nearSup ? "AT SUPPORT" : "INSIDE CHANNEL"
string playbook = not intradayOk ? "Open an intraday chart (5m-1h)." : not hasMap ? "Waiting for a completed anchor." : nearRes ? "Watch rejection." : nearSup ? "Watch support hold." : "Inside channel. Wait for a shelf test."
color mapColor = nearRes ? colRes : nearSup ? colSup : color.new(colMuted, 15)

bgcolor(showGlow and intradayOk ? (nearRes ? color.new(colRes, 92) : nearSup ? color.new(colSup, 92) : na) : na, title="Shelf approach glow", editable=false)

if nearRes and not nearRes[1]
    send("PROPHET MAP: " + resLayer + " resistance near " + fmt(nRes) + ". Watch rejection.")
if nearSup and not nearSup[1]
    send("PROPHET MAP: " + supLayer + " support near " + fmt(nSup) + ". Watch support hold.")

// ---------------------------------------------------------------------------
// Drawing -- time-anchored lines, extended right. Redrawn only on the last bar.
// ---------------------------------------------------------------------------
timeLine(int t1, float y1, int t2, float y2, color col, int w, string st) =>
    line ln = line.new(t1, y1, t2, y2, xloc=xloc.bar_time, extend=extend.right, color=col, width=w, style=st)
    array.push(lines, ln)
    ln

addLabel(string txt, float yNow, color col, string sz, float slopePerBar) =>
    int tl = time + 10 * tfMs
    float yl = yNow - slopePerBar * 10
    label lb = label.new(tl, yl, txt + "\n" + fmt(yNow), xloc=xloc.bar_time, style=label.style_label_left, color=color.new(col, 10), textcolor=color.white, size=sz)
    array.push(labels, lb)

// Weekly band: from the anchor point to now, extended right. yA is the gate's
// value back at the anchor time.
drawBand(int tA, float yA, float yNow, string txt, color col) =>
    if not na(yNow)
        float half = zoneWidth / 2.0
        timeLine(tA, yA, time, yNow, color.new(col, 0), 3, line.style_solid)
        line top = timeLine(tA, yA + half, time, yNow + half, color.new(col, 65), 1, line.style_solid)
        line bot = timeLine(tA, yA - half, time, yNow - half, color.new(col, 65), 1, line.style_solid)
        array.push(fills, linefill.new(top, bot, color.new(col, 88)))
        addLabel(txt, yNow, col, size.small, perBar)

drawDailyLine(int tA, float yA, float yNow, string txt, color col) =>
    if not na(yNow)
        timeLine(tA, yA, time, yNow, color.new(col, 25), 1, line.style_dashed)
        addLabel(txt, yNow, color.new(col, 25), size.tiny, perBar)

// Macro rail: drawn as a zone with the same anatomy as the weekly shelves
// (dark purple center line, faint edges, soft fill). dir: -1 descending,
// +1 ascending. The left end anchors at the lattice's true anchor date when
// that date is inside the loaded chart history (daily and higher intraday
// charts); otherwise it anchors at the first loaded bar with the exact
// value computed from the daily-bar count, so the rail renders correctly
// down to the 1-minute chart. Both endpoints are always exact.
drawMacroRail(float g, int dir, string txt) =>
    if not na(g) and not na(tMacroFirst)
        int aDate = dir == -1 ? descDate : ascDate
        bool anchorLoaded = aDate >= tMacroFirst
        int daysBack = dir == -1 ? tdDesc - tdDescFirst : tdAsc - tdAscFirst
        float ctrl = dir == -1 ? mDesc : mAsc
        int aT = anchorLoaded ? aDate : tMacroFirst
        float aP = anchorLoaded ? (dir == -1 ? descPrice : ascPrice) + (g - ctrl) : g - dir * macroSlope * daysBack
        float half = macroZone / 2.0
        timeLine(aT, aP, time, g, color.new(colMacro, 5), 2, line.style_solid)
        if half > 0
            line top = timeLine(aT, aP + half, time, g + half, color.new(colMacro, 68), 1, line.style_solid)
            line bot = timeLine(aT, aP - half, time, g - half, color.new(colMacro, 68), 1, line.style_solid)
            array.push(fills, linefill.new(top, bot, color.new(colMacro, 90)))
        addLabel(txt, g, color.new(colMacro, 10), size.tiny, 0)

drawWeeklyGuide(int tA, float yA, float yNow) =>
    if not na(yNow)
        timeLine(tA, yA, time, yNow, colGuide, 1, line.style_dotted)

if barstate.islast
    clearObjects()
    // Macro Lattice first -- background context. All four in-play rails:
    // support and resistance from both the descending and ascending grids.
    if macroLive
        drawMacroRail(mdHi, -1, "Macro Resistance (Desc)")
        drawMacroRail(maHi, 1, "Macro Resistance (Asc)")
        drawMacroRail(mdLo, -1, "Macro Support (Desc)")
        drawMacroRail(maLo, 1, "Macro Support (Asc)")
    // Daily Control -- secondary, thin dashed.
    if dailyLive
        drawDailyLine(aDT, aDH + (dRes - dNow), dRes, "Daily Resistance", colRes)
        drawDailyLine(aDT, aDH + (dSup - dNow), dSup, "Daily Support", colSup)
    // Weekly Control -- primary, drawn last so it sits on top.
    if weeklyLive
        drawBand(aWT, aWH + (wRes - wNow), wRes, "Weekly Resistance", colRes)
        drawBand(aWT, aWH + (wSup - wNow), wSup, "Weekly Support", colSup)
        if showWeeklyGuides
            drawWeeklyGuide(aWT, aWH + (wRes + shelfSpacing - wNow), wRes + shelfSpacing)
            drawWeeklyGuide(aWT, aWH + (wSup - shelfSpacing - wNow), wSup - shelfSpacing)

// ---------------------------------------------------------------------------
// Map panel
// ---------------------------------------------------------------------------
panelPos = panelPosIn == "Top left" ? position.top_left : panelPosIn == "Bottom right" ? position.bottom_right : panelPosIn == "Bottom left" ? position.bottom_left : panelPosIn == "Middle right" ? position.middle_right : position.top_right
var table panel = table.new(panelPos, 3, 10, bgcolor=colPanel, frame_color=color.new(colMuted, 45), frame_width=1)

trow(int r, string a, string b, string c, color bc, string tip) =>
    table.cell(panel, 0, r, a, text_color=colMuted, text_size=size.tiny, text_halign=text.align_left, tooltip=tip)
    table.cell(panel, 1, r, b, text_color=bc, text_size=size.tiny, text_halign=text.align_left)
    table.cell(panel, 2, r, c, text_color=colMuted, text_size=size.tiny, text_halign=text.align_right)

if barstate.islast and showPanel
    table.clear(panel, 0, 0, 2, 9)
    table.cell(panel, 0, 0, "PROPHET", text_color=colText, bgcolor=colHdr, text_size=size.small)
    table.cell(panel, 1, 0, "MAP", text_color=colText, bgcolor=colHdr, text_size=size.small)
    table.cell(panel, 2, 0, mapState, text_color=mapColor, bgcolor=colHdr, text_size=size.small, text_halign=text.align_right)
    trow(1, "Resistance", fmt(nRes) + " | " + resLayer, na(distRes) ? "-" : str.tostring(distRes, "#.##") + " away", colRes, "Nearest resistance above price and which layer it comes from (Weekly / Daily / Macro).")
    trow(2, "Support", fmt(nSup) + " | " + supLayer, na(distSup) ? "-" : str.tostring(distSup, "#.##") + " away", colSup, "Nearest support below price and which layer it comes from (Weekly / Daily / Macro).")
    trow(3, "RTH", rthOpen ? "Open" : "Closed", "8:30-3:00 CT", rthOpen ? colSup : colMuted, "Regular trading hours status.")
    trow(4, "Playbook", playbook, "", colText, "Plain-English read of the map right now.")
    trow(5, "Weekly", na(wNow) ? "waiting for Monday anchor" : fmt(aWH) + " -> " + fmt(wNow), "Mon 12-2:30 high", colText, "Weekly Control: Monday 12:00-2:30pm CT high wick, falling " + str.tostring(slopeHour, "#.##") + " pts per trading hour. Shown as anchor price -> current control value. Anchor and value are computed on 30-minute data, identical on every intraday interval.")
    string dailyStatus = na(aDH) ? "no 4-5am data" : not dailyToday ? "waiting for today's window" : not dailyWindowOn ? "ready | active 8:50am" : fmt(aDH) + " -> " + fmt(dNow)
    trow(6, "Daily", dailyStatus, "4-5am high", colText, "Daily Control: same-day 4:00-5:00am CT high wick, same slope and spacing. Draws from 8:50am CT. Computed on 5-minute data. Needs premarket bars (ES futures); SPX index charts have none.")
    trow(7, "Macro Desc", macroLive ? "S " + fmt(mdLo) + " | R " + fmt(mdHi) : (isSpyProfile ? "SPX/ES only" : "waiting for daily data"), macroLive ? "ctrl " + fmt(mDesc) : "", colMacro, "Descending macro lattice: control falling " + str.tostring(macroSlope, "#.##") + " pts per actual trading day from " + str.tostring(descPrice, "#.##") + " (Jun 3 2026), gates every " + str.tostring(macroSpace, "#") + " pts. S/R are its in-play rails around price; ctrl is the control value today. Trading days are counted from the symbol's daily bars, so holidays do not shift the grid.")
    trow(8, "Macro Asc", macroLive ? "S " + fmt(maLo) + " | R " + fmt(maHi) : "", macroLive ? "ctrl " + fmt(mAsc) : "", colMacro, "Ascending macro lattice: control rising " + str.tostring(macroSlope, "#.##") + " pts per actual trading day from " + str.tostring(ascPrice, "#.##") + " (Jun 11 2026), gates every " + str.tostring(macroSpace, "#") + " pts. S/R are its in-play rails around price; ctrl is the control value today.")
    trow(9, "Note", "Macro grid is fixed; the in-play rails step when price enters a new " + str.tostring(macroSpace, "#") + "-pt zone", "", colMuted, "The lattices themselves never move. What changes is which rail of each lattice is closest to price: cross into the next " + str.tostring(macroSpace, "#") + "-pt zone and that lattice's in-play support/resistance snaps to the next rail.")

// ---------------------------------------------------------------------------
// Hidden bridge outputs for Prophet Engine Pro
// ---------------------------------------------------------------------------
float activeGate = na(nSup) ? nRes : na(nRes) ? nSup : (close - nSup <= nRes - close ? nSup : nRes)
float activeGateDist = na(activeGate) ? na : math.abs(close - activeGate)
int biasCode = hasMap ? (close > nRes ? 1 : close < nSup ? -1 : 0) : 0
plot(activeGate, title="PM Nearest diagonal gate", display=display.none)
plot(activeGateDist, title="PM Diagonal gate distance", display=display.none)
plot(nSup, title="PM Nearest support", display=display.none)
plot(nRes, title="PM Nearest resistance", display=display.none)
plot(biasCode, title="PM Bias code", display=display.none)
alertcondition(nearRes or nearSup, title="Prophet Map shelf approach", message="Use Any alert() function call for detailed Prophet Map messages.")
